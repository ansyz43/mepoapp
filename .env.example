# ─── Database ───────────────────────────────────────────────
DB_PASSWORD=changeme                          # Postgres password

# ─── Security (REQUIRED — app won't start without a real key) ──
SECRET_KEY=generate-a-64-char-random-string   # openssl rand -hex 32

# ─── OpenAI / LLM ──────────────────────────────────────────
OPENAI_API_KEY=sk-or-v1-...                   # OpenRouter or OpenAI API key
OPENAI_BASE_URL=https://openrouter.ai/api/v1  # Leave empty for direct OpenAI

# ─── Meta Platform (REQUIRED) ──────────────────────────────
META_APP_ID=                                  # Meta App ID from developers.facebook.com
META_APP_SECRET=                              # Meta App Secret
META_WEBHOOK_VERIFY_TOKEN=                    # Random string for webhook verification
META_API_VERSION=v21.0                        # Graph API version

# ─── Apple Sign In (REQUIRED for iOS) ─────────────────────
APPLE_CLIENT_ID=                              # Bundle ID (e.g. com.meepo.app)
APPLE_TEAM_ID=                                # Apple Developer Team ID
APPLE_KEY_ID=                                 # Key ID from Apple Developer Portal
APPLE_PRIVATE_KEY=                            # .p8 key contents (base64 or raw)

# ─── Web / CORS ────────────────────────────────────────────
CORS_ORIGINS=*                                # Comma-separated origins (or * for development)

# ─── OAuth (optional) ──────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Email (optional — reset password) ─────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ─── APNs Push Notifications ──────────────────────────────
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=
APNS_KEY_PATH=                                # Path to .p8 key file

# ─── Cloudflare AI Gateway (optional) ──────────────────────
CF_AIG_TOKEN=

# ─── Monitoring (optional) ─────────────────────────────────
SENTRY_DSN=
ALERT_EMAIL=
ALERT_SLACK_WEBHOOK=
